{
  "version": 2,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/offline.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/bangkok",
      "destination": "/bangkok.html"
    },
    {
      "source": "/bangkok/",
      "destination": "/bangkok.html"
    },
    {
      "source": "/bangkok/hotell",
      "destination": "/bangkok-hotell.html"
    },
    {
      "source": "/bangkok/hotell/",
      "destination": "/bangkok-hotell.html"
    },
    {
      "source": "/bangkok/natteliv",
      "destination": "/bangkok-natteliv.html"
    },
    {
      "source": "/bangkok/natteliv/",
      "destination": "/bangkok-natteliv.html"
    },
    {
      "source": "/bangkok/shopping",
      "destination": "/bangkok-shopping.html"
    },
    {
      "source": "/bangkok/shopping/",
      "destination": "/bangkok-shopping.html"
    },
    {
      "source": "/bangkok/restauranter",
      "destination": "/bangkok-restauranter.html"
    },
    {
      "source": "/bangkok/restauranter/",
      "destination": "/bangkok-restauranter.html"
    },
    {
      "source": "/bangkok/familie",
      "destination": "/bangkok-familie.html"
    },
    {
      "source": "/bangkok/familie/",
      "destination": "/bangkok-familie.html"
    },
    {
      "source": "/bangkok/spa",
      "destination": "/bangkok-spa.html"
    },
    {
      "source": "/bangkok/spa/",
      "destination": "/bangkok-spa.html"
    }
  ]
}
