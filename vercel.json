{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": false,
  "headers": [
    {"source": "/assets/(.*)", "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]},
    {"source": "/(.*).js", "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]},
    {"source": "/(.*).css", "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]}
  ],
  "rewrites": [
    {"source": "/bangkok", "destination": "/bangkok.html"},
    {"source": "/bangkok/", "destination": "/bangkok.html"},
    {"source": "/bangkok/hotell", "destination": "/bangkok-hotell.html"},
    {"source": "/bangkok/hotell/", "destination": "/bangkok-hotell.html"},
    {"source": "/bangkok/natteliv", "destination": "/bangkok-natteliv.html"},
    {"source": "/bangkok/natteliv/", "destination": "/bangkok-natteliv.html"},
    {"source": "/bangkok/shopping", "destination": "/bangkok-shopping.html"},
    {"source": "/bangkok/shopping/", "destination": "/bangkok-shopping.html"},
    {"source": "/bangkok/restauranter", "destination": "/bangkok-restauranter.html"},
    {"source": "/bangkok/restauranter/", "destination": "/bangkok-restauranter.html"},
    {"source": "/bangkok/familie", "destination": "/bangkok-familie.html"},
    {"source": "/bangkok/familie/", "destination": "/bangkok-familie.html"},
    {"source": "/bangkok/spa", "destination": "/bangkok-spa.html"},
    {"source": "/bangkok/spa/", "destination": "/bangkok-spa.html"}
  ]
}
